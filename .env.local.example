# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google AI (for AI content generation via Gemma)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# Cloudflare (for image uploads)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_IMAGES_API_TOKEN=your-api-token

# Cloudflare R2 (for published sites)
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=curiouscirkits-sites
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Cloudflare Workers KV
CF_KV_NAMESPACE_ID=your-kv-namespace-id
CF_API_TOKEN=your-cf-api-token
